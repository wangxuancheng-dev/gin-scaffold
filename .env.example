# Application
APP_ENV=dev
DEBUG=true

HTTP_PORT=8080

HTTP_HOST=0.0.0.0
HTTP_READ_TIMEOUT_SEC=30
HTTP_READ_HEADER_TIMEOUT_SEC=10
HTTP_WRITE_TIMEOUT_SEC=30
HTTP_IDLE_TIMEOUT_SEC=120
HTTP_SHUTDOWN_TIMEOUT_SEC=10
HTTP_MAX_BODY_BYTES=1048576

# Database（MySQL 不必写 loc=，与下面 TIME_ZONE / db.time_zone 一致，由 pkg/db 注入驱动）
DB_DSN=root:root@tcp(127.0.0.1:3306)/scaffold?charset=utf8mb4&parseTime=True
# 数据库会话时区（MySQL: SET time_zone；PG: SET TIME ZONE），与 configs 中 db.time_zone 一致；启动后同步为进程 time.Local，Gin 与普通 time.Now() 与此一致
TIME_ZONE=UTC

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

# Asynq
ASYNQ_REDIS_ADDR=127.0.0.1:6379
ASYNQ_REDIS_PASSWORD=
ASYNQ_REDIS_DB=1
ASYNQ_CONCURRENCY=10
ASYNQ_STRICT_PRIORITY=false
ASYNQ_QUEUE=default
ASYNQ_MAX_RETRY=5
ASYNQ_TIMEOUT_SEC=30
ASYNQ_DEDUP_WINDOW_SEC=30

# JWT
JWT_SECRET=please-change-me
RBAC_SUPER_ADMIN_USER_ID=1

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces

# Outbound HTTP client governance
OUTBOUND_TIMEOUT_MS=3000
OUTBOUND_RETRY_MAX=2
OUTBOUND_RETRY_BACKOFF_MS=200
OUTBOUND_CIRCUIT_THRESHOLD=10
OUTBOUND_CIRCUIT_OPEN_SEC=30

# File storage
STORAGE_SIGN_SECRET=replace-with-your-own-storage-sign-secret
# 逗号分隔，与 http.DetectContentType 嗅探结果比对；留空则使用 configs 中 storage.allowed_mime
# STORAGE_ALLOWED_MIME=image/jpeg,image/png,application/pdf,text/plain
# S3 / MinIO（storage.driver 为 s3 或 minio 时使用）
# STORAGE_S3_ENDPOINT=https://minio.example.com
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_BUCKET=gin-scaffold
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=
# STORAGE_S3_PATH_STYLE=true
# STORAGE_S3_INSECURE=false
# /readyz 是否检查存储（HeadBucket 或本地目录）；需 storage.enabled=true
# STORAGE_READYZ_CHECK=false
