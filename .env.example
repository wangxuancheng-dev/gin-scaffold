# Application
APP_ENV=dev

HTTP_PORT=8080

HTTP_HOST=0.0.0.0

# Database
DB_DSN=root:root@tcp(127.0.0.1:3306)/scaffold?charset=utf8mb4&parseTime=True&loc=UTC
# 数据库会话时区（MySQL: SET time_zone；PG: SET TIME ZONE），与 configs 中 db.session_time_zone 一致；启动后同步为进程 time.Local，Gin 与普通 time.Now() 与此一致
TIME_ZONE=UTC

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=please-change-me

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces
