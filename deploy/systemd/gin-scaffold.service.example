[Unit]
Description=gin-scaffold api service
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/gin-scaffold
EnvironmentFile=/opt/gin-scaffold/.env.prod
ExecStart=/opt/gin-scaffold/bin/server server --env prod
ExecReload=/bin/kill -HUP $MAINPID
Restart=always
RestartSec=3
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
