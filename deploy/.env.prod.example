# gin-scaffold production environment variables
# Copy to /opt/gin-scaffold/.env.prod and replace placeholders.

# Required
APP_ENV=prod
DEBUG=false
HTTP_READ_TIMEOUT_SEC=30
HTTP_READ_HEADER_TIMEOUT_SEC=10
HTTP_WRITE_TIMEOUT_SEC=30
HTTP_IDLE_TIMEOUT_SEC=120
HTTP_SHUTDOWN_TIMEOUT_SEC=20
DB_DSN=root:change-me@tcp(127.0.0.1:3306)/scaffold?charset=utf8mb4&parseTime=True
TIME_ZONE=UTC
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=change-me
ASYNQ_REDIS_ADDR=127.0.0.1:6379
ASYNQ_REDIS_PASSWORD=change-me
ASYNQ_REDIS_DB=1
ASYNQ_CONCURRENCY=20
ASYNQ_STRICT_PRIORITY=false
ASYNQ_QUEUE=default
ASYNQ_MAX_RETRY=8
ASYNQ_TIMEOUT_SEC=60
ASYNQ_DEDUP_WINDOW_SEC=30
JWT_SECRET=replace-with-a-long-random-secret
RBAC_SUPER_ADMIN_USER_ID=1

# Optional but recommended
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces

# Optional profile flag (usually passed by CLI --profile)
# APP_PROFILE=order
