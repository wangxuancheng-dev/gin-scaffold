# 本文件用于本地私有覆盖（不要提交真实凭据）。
# 使用方式：
# 1) 复制为 configs/app.local.yaml
# 2) 按本机环境修改
# 3) 启动时可将 app.local 的值通过环境变量覆盖到 app.yaml/app.test.yaml

env: dev
name: gin-scaffold-local

db:
  driver: mysql
  dsn: "root:root@tcp(127.0.0.1:3306)/scaffold?charset=utf8mb4&parseTime=True&loc=Local"

redis:
  addr: "127.0.0.1:6379"
  password: ""
  db: 0

jwt:
  secret: "local-secret-change-me"
